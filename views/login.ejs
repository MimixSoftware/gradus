<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="robots" content="noindex, nofollow">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="login">
		<section class="auth">
			<div class="auth-card">
				<img src="/images/logo.svg" alt="Gradus logo" class="logo-icon auth-logo" />
				<img src="/images/logo-white.svg" alt="Gradus logo" class="logo-icon logo-white auth-logo" />

				<h1>Login</h1>
				<p class="auth-subtitle">Welcome back. Continue where you left off.</p>

				<div
					id="auth-error"
					class="alert"
					style="display: none;"
					role="alert"
				></div>

				<form class="form" id="login-form">
					<div class="form-row">
						<label for="email">Email</label>
						<input
							id="email"
							name="email"
							type="email"
							autocomplete="email"
							required
						>
					</div>

					<div class="form-row">
						<label for="password">Password</label>
						<input
							id="password"
							name="password"
							type="password"
							autocomplete="current-password"
							required
						>
					</div>

					<button class="btn btn-primary btn-large form-submit" type="submit">
						Login
					</button>

					<div class="auth-links">
						<span>
							Don’t have an account?
							<a href="/register">Register</a>
						</span>
						<a href="/forgot-password">Forgot password?</a>
					</div>
				</form>
			</div>
		</section>
	</main>

	<%- include('partials/footer') %>

	<script src="/js/main.js?v=<%= assetVersion %>"></script>
</body>
</html>
