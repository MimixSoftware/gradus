<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="robots" content="noindex, nofollow">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="statistics">
		<div class="container">

			<header class="ui-header">
				<div class="ui-title">
					<h1>Statistics</h1>
					<div class="ui-subline">
						The current semester at a glance.
					</div>
				</div>
			</header>

			<section class="ui-grid">
				<article class="ui-card">
					<h2 class="ui-card-title">Overview</h2>

					<ul id="statistics-overview-list" class="ui-list ui-list--editable"></ul>
				</article>

				<article class="ui-card">
					<h2 class="ui-card-title">Analytics</h2>

					<div class="ui-field">
						<select id="statistics-analytics-select" class="ui-input">
							<option value=""></option>
						</select>
					</div>

					<div class="statistics-chart-wrap">
						<canvas id="statistics-chart"></canvas>
					</div>
				</article>

				<article class="ui-card">
					<h2 class="ui-card-title">Insights</h2>

					<ul id="statistics-insights-list" class="ui-list ui-list--editable"></ul>
				</article>
			</section>

		</div>
	</main>

	<%- include('partials/footer') %>

	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script src="/js/main.js?v=<%= assetVersion %>"></script>
</body>
</html>