<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="robots" content="noindex, nofollow">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="forgotPassword">
		<section class="auth">
			<div class="auth-card">
				<img
					src="/images/logo.png"
					alt="Gradus logo"
					class="auth-logo"
				>

				<h1>Forgot password</h1>
				<p class="auth-subtitle">Enter your email address and we’ll send you a link to reset your password.</p>

				<div
					id="auth-error"
					class="alert alert-error"
					style="display: none;"
					role="alert"
				></div>

				<form class="form" id="forgot-password-form">
					<div class="form-row">
						<label for="email">Email</label>
						<input
							id="email"
							name="email"
							type="email"
							autocomplete="email"
							required
						>
					</div>

					<button class="btn btn-primary btn-large form-submit" type="submit">
						Request reset link
					</button>

					<p class="auth-alt">
						Remembered your password?
						<a href="/login">Login</a>
					</p>
				</form>
			</div>
		</section>
	</main>

	<%- include('partials/footer') %>

	<script src="/js/main.js?v=<%= assetVersion %>"></script>
</body>
</html>
