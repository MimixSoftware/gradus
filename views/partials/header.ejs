<header class="site-header">
	<div class="header-inner">
		<div class="logo">
			<a href="/" class="logo-link">
				<img src="/images/logo.svg" alt="Gradus logo" class="logo-icon" />
				<img src="/images/logo-white.svg" alt="Gradus logo" class="logo-icon logo-white" />
				<span class="logo-text">Gradus</span>
			</a>
		</div>

		<nav class="nav">
			<button class="nav-toggle" type="button">
				<span class="burger"></span>
			</button>

			<div class="nav-menu" id="nav-menu">
				<% if (user) { %>
					<a href="/dashboard" class="nav-link">Dashboard</a>
					<a href="/schedule" class="nav-link">My Schedule</a>
					<a href="/statistics" class="nav-link">Statistics</a>
					<a href="/settings" class="nav-link">Settings</a>
					<a href="#" id="logout-link" class="btn btn-primary">Logout</a>
				<% } else { %>
					<a href="/login" class="nav-link">Login</a>
					<a href="/register" class="btn btn-primary">Register</a>
				<% } %>
			</div>
		</nav>

	</div>
</header>
