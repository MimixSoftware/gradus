<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="robots" content="noindex, nofollow">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="resetPassword">
		<section class="auth">
			<div class="auth-card">
				<img src="/images/logo.svg" alt="Gradus logo" class="logo-icon auth-logo" />
				<img src="/images/logo-white.svg" alt="Gradus logo" class="logo-icon logo-white auth-logo" />

				<h1>Reset password</h1>
				<% if (!tokenValid) { %>
					<p class="auth-subtitle">Invalid or expired verification code.</p>

					<a href="/forgot-password" class="btn btn-primary btn-large">Request new reset link</a>
				<% } else { %>
					<p class="auth-subtitle">Enter your new password below.</p>

					<div
						id="auth-alert"
						class="alert"
						style="display: none;"
						role="alert"
					></div>

					<form class="form" id="reset-password-form">
						<div class="form-row">
							<label for="password">Password <span class="required">*</span></label>
							<input
								id="new-password"
								name="newPassword"
								type="password"
								autocomplete="new-password"
								required
							>
							<p class="field-hint">Use at least 8 characters.</p>
						</div>

						<div class="form-row">
							<label for="confirm-password">Confirm password <span class="required">*</span></label>
							<input
								id="confirm-password"
								name="confirmPassword"
								type="password"
								autocomplete="new-password"
								required
							>
						</div>

						<button class="btn btn-primary btn-large form-submit" type="submit">
							Reset password
						</button>

						<p class="auth-alt">
							Back to
							<a href="/login">Login</a>
						</p>
					</form>
				<% } %>
			</div>
		</section>
	</main>

	<%- include('partials/footer') %>

	<script src="/js/main.js?v=<%= assetVersion %>"></script>
</body>
</html>
