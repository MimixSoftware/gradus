<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="robots" content="noindex, nofollow">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="assignment" data-assignment-id="<%= assignmentId %>">
		<div class="container">

			<header class="ui-header">
				<div class="ui-title">
					<h1 class="assignment-title-row">
						<span class="ui-name assignment-name"><%= assignmentName %></span>
						<span class="assignment-status ui-item-status" style="display:none;"></span>
					</h1>

					<div class="ui-subline">
						<span>
							Module:
							<strong class="assignment-module-name">-</strong>
						</span>

						<span>•</span>

						<span>
							Due:
							<strong class="assignment-due-date">-</strong>
						</span>
					</div>
				</div>

				<div class="ui-meta">
					<div class="ui-actions" style="margin-top: 0;">
						<button type="button" class="btn btn-small" data-action="toggle-assignment-status">Complete</button>
						<button type="button" class="btn btn-small" data-modal-open="edit-assignment-modal">Edit</button>
						<button type="button" class="btn btn-small btn-danger" data-modal-open="delete-assignment-modal">Delete</button>
					</div>
				</div>
			</header>

			<div id="info-banner" class="info-banner" style="display: none;"></div>

			<section class="ui-grid">

				<article class="ui-card">
					<h2 class="ui-card-title">To Do</h2>

					<ul class="ui-list ui-list--editable" data-list="todo"></ul>

					<div class="ui-actions">
						<button type="button" class="btn btn-small" data-modal-open="new-task-modal">New</button>
					</div>
				</article>

				<article class="ui-card">
					<h2 class="ui-card-title">Doing</h2>

					<ul class="ui-list ui-list--editable" data-list="doing"></ul>

					<div class="ui-actions"></div>
				</article>

				<article class="ui-card">
					<h2 class="ui-card-title">Done</h2>

					<ul class="ui-list ui-list--editable" data-list="done"></ul>

					<div class="ui-actions"></div>
				</article>

			</section>

		</div>
	</main>

	<%- include('partials/footer') %>

	<!-- Edit Assignment Modal -->
	<div class="modal" id="edit-assignment-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title" id="edit-assignment-title">Edit Assignment</div>
					<div class="field-hint">Update assignment details.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="edit-assignment-form">
				<div
					id="ea-error"
					class="alert"
					style="display: none;"
					role="alert"
				>Test</div>

				<div class="form-row">
					<label for="ea-name">Assignment name <span class="required">*</span></label>
					<input id="ea-name" name="name" type="text" maxlength="100" required />

					<label for="ea-deadline">Deadline</label>
					<input id="ea-deadline" name="deadline" type="datetime-local" />
					<div class="field-hint">Optional. Leave empty if you don’t have a deadline yet.</div>
				</div>

				<div class="form-row">
					<label for="ea-description">Description</label>
					<textarea id="ea-description" name="description" maxlength="500" placeholder="Optional notes, word count requirements, marking scheme, etc."></textarea>
				</div>

				<div class="form-row">
					<div class="range-row">
						<label for="ea-weight">Weight</label>
						<div class="range-value"><span id="ea-weight-val">0</span>%</div>
					</div>
					<input id="ea-weight" name="weight" type="range" min="0" max="100" step="1" value="0" />
				</div>

				<div class="form-row">
					<div class="range-row">
						<label for="ea-confidence">Confidence</label>
						<div class="range-value"><span id="ea-confidence-val">0</span>/5</div>
					</div>
					<input id="ea-confidence" name="confidence" type="range" min="0" max="5" step="1" value="0" />
					<div class="field-hint">0 = no clue yet, 5 = very confident.</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="edit-assignment-form">Save</button>
			</footer>
		</div>
	</div>

	<!-- Delete Assignment Modal -->
	<div class="modal" id="delete-assignment-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title" id="delete-assignment-title">Delete Assignment</div>
					<div class="field-hint">This action cannot be undone.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="delete-assignment-form">
				<div id="da-error" class="alert" style="display:none;" role="alert"></div>

				<div class="modal-warning">
					<div id="da-message" class="modal-warning-text">
						Are you sure you want to delete this assignment?
					</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-danger" form="delete-assignment-form">Delete</button>
			</footer>
		</div>
	</div>

	<!-- New Task Modal -->
	<div class="modal" id="new-task-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">New Task</div>
					<div class="field-hint">Create a task under an assignment.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="new-task-form">
				<div id="nt-info-banner" class="info-banner" style="display: none;"></div>

				<div id="nt-error" class="alert" style="display: none;"role="alert"></div>

				<div class="form-row">
					<label for="nt-name">Task name <span class="required">*</span></label>
					<input id="nt-name" name="name" type="text" maxlength="100" required placeholder="e.g. Write introduction" />
				</div>

				<div class="form-row">
					<label for="nt-deadline">Deadline</label>
					<input id="nt-deadline" name="deadline" type="datetime-local" />
					<div class="field-hint">Optional.</div>
				</div>

				<div class="form-row">
					<label for="nt-description">Description</label>
					<textarea id="nt-description" name="description" maxlength="500" placeholder="Optional notes, word count requirements, etc."></textarea>
				</div>

				<div class="form-row">
					<div class="range-row">
						<label for="nt-etc">Estimated Time (minutes)</label>
						<button type="button" class="btn btn-small" id="nt-estimate-btn">Estimate</button>
					</div>

					<input id="nt-etc" name="etcMinutes" type="number" min="15" max="1440" step="15" />

					<div class="field-hint">
						How long you think this task will take. Enter manually or let Gradus estimate based on task and assignment details.
					</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="new-task-form">Create</button>
			</footer>
		</div>
	</div>

	<!-- Edit Task Modal -->
	<div class="modal" id="edit-task-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">Edit Task</div>
					<div class="field-hint">Update task details.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="edit-task-form">
				<input type="hidden" id="et-id" name="id" />

				<div id="et-error" class="alert" style="display: none;"role="alert"></div>

				<div class="form-row">
					<label for="et-name">Task name <span class="required">*</span></label>
					<input id="et-name" name="name" type="text" maxlength="100" required placeholder="e.g. Write introduction" />
				</div>

				<div class="form-row">
					<label for="et-status">Status <span class="required">*</span></label>
					<select id="et-status" name="status" required>
						<option value="todo">To Do</option>
						<option value="doing">Doing</option>
						<option value="done">Done</option>
					</select>
				</div>

				<div class="form-row">
					<label for="et-deadline">Deadline</label>
					<input id="et-deadline" name="deadline" type="datetime-local" />
					<div class="field-hint">Optional.</div>
				</div>

				<div class="form-row">
					<label for="et-description">Description</label>
					<textarea id="et-description" name="description" maxlength="500" placeholder="Optional notes, word count requirements, etc."></textarea>
				</div>

				<div class="form-row">
					<div class="range-row">
						<label for="et-etc">Estimated Time (minutes)</label>
						<button type="button" class="btn btn-small" id="et-estimate-btn">Estimate</button>
					</div>

					<input id="et-etc" name="etcMinutes" type="number" min="15" max="1440" step="15" />

					<div class="field-hint">
						How long you think this task will take. Enter manually or let Gradus estimate based on task and assignment details.
					</div>
				</div>

				<div class="form-row" id="et-atc-row" style="display: none;">
					<label for="et-atc">Actual Time (minutes)</label>
					<input id="et-atc" name="atcMinutes" type="number" min="1" max="1440" step="1" />
					<div class="field-hint">
						Optional. How long it actually took you to complete this task.
					</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="edit-task-form">Save</button>
			</footer>
		</div>
	</div>

	<!-- Delete Task Modal -->
	<div class="modal" id="delete-task-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title" id="delete-module-title">Delete Task</div>
					<div class="field-hint">This action cannot be undone.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="delete-task-form">
				<input type="hidden" id="dt-id" name="id" />

				<div id="dt-error" class="alert" style="display:none;" role="alert"></div>

				<div class="modal-warning">
					<div id="dt-message" class="modal-warning-text">
						Are you sure you want to delete this task?
					</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-danger" form="delete-task-form">Delete</button>
			</footer>
		</div>
	</div>

	<!-- Complete Task Modal -->
	<div class="modal" id="complete-task-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">Complete Task</div>
					<div class="field-hint">Task marked as done. Add the actual time if you’d like.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="complete-task-form">
				<input type="hidden" id="ct-id" name="id" />

				<div id="ct-error" class="alert" style="display: none;"role="alert"></div>

				<div class="form-row">
					<label for="ct-atc">Actual Time (minutes)</label>
					<input id="ct-atc" name="atcMinutes" type="number" min="1" max="1440" step="1" />
					<div class="field-hint">
						Optional. How long it actually took you to complete this task.
					</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Skip</button>
				<button type="submit" class="btn btn-small btn-primary" form="complete-task-form">Complete</button>
			</footer>
		</div>
	</div>

    <script src="/js/main.js?v=<%= assetVersion %>"></script>
</body>
</html>
