<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> - Gradus</title>
	<link rel="icon" href="/images/favicon.ico">
	<link rel="stylesheet" href="/css/style.css">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="studySessions">
		<div class="container">

			<header class="ui-header">
				<div class="ui-title">
					<h1>Study Sessions</h1>
					<div class="ui-subline">
						<span id="active-semester-name"></span>
						<a class="ui-link" href="#" data-modal-open="semester-modal">Manage Semesters</a>
					</div>
				</div>
			</header>

			<section class="ui-grid ui-grid--single">
				<article class="ui-card">
					<h2 class="ui-card-title">Your Weekly Sessions</h2>

					<div class="ui-list scroll-container" data-list="studySessions"></div>

					<div class="ui-actions">
						<button type="button" class="btn btn-small" data-modal-open="new-study-session-modal">New</button>
					</div>
				</article>
			</section>

		</div>
	</main>

	<%- include('partials/footer') %>

	<!-- Change Semester Modal -->
	<div class="modal" id="semester-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
			<div>
				<div class="modal-title" id="semester-modal-title">Semesters</div>
				<div class="field-hint">Set your active semester, or manage semesters.</div>
			</div>

			<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<div class="modal-body form">
				<!-- SCREEN A: List and Pick -->
				<section id="semester-screen-list">
					<div
						id="sm-error"
						class="alert alert-error"
						style="display:none;"
						role="alert"
					></div>

					<div class="form-row">
					<label for="sm-active">Active semester</label>
					<select id="sm-active" name="activeSemesterId">
						<option value="" disabled selected>Select a semester…</option>
						<!-- populated by JS -->
					</select>
					<div class="field-hint">This controls what shows on your dashboard.</div>
					</div>

					<ul class="ui-list ui-list--editable" data-list="semesters"></ul>

					<div class="ui-actions">
					<button type="button" class="btn btn-small" id="sm-new-btn">New</button>
					</div>
				</section>

				<!-- SCREEN B: Create/Edit -->
				<section id="semester-screen-form" style="display:none;">
					<div
					id="sm-form-error"
					class="alert alert-error"
					style="display:none;"
					role="alert"
					></div>

					<form id="semester-form" class="form">
					<input type="hidden" id="sm-id" name="id" value="" />

					<div class="form-row">
						<label for="sm-name">Semester name</label>
						<input id="sm-name" name="name" type="text" maxlength="100" required placeholder="e.g. Spring 2026" />
					</div>

					<div class="form-grid">
						<div class="form-row">
						<label for="sm-start">Start date</label>
						<input id="sm-start" name="startDate" type="date" required />
						</div>

						<div class="form-row">
						<label for="sm-end">End date</label>
						<input id="sm-end" name="endDate" type="date" required />
						</div>
					</div>
					</form>
				</section>
			</div>

			<footer class="modal-footer">
				<div id="semester-footer-list">
					<button type="button" class="btn btn-small" data-modal-close>Close</button>
					<button type="button" class="btn btn-small btn-primary" id="sm-set-active-btn">Set Active</button>
				</div>

				<div id="semester-footer-form" style="display:none;">
					<button type="button" class="btn btn-small" id="sm-cancel-form-btn">Cancel</button>
					<button type="submit" class="btn btn-small btn-primary" form="semester-form" id="sm-save-btn">Save</button>
				</div>
			</footer>
		</div>
	</div>

	<!-- Delete Semester Modal -->
	<div class="modal" id="delete-semester-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title" id="delete-semester-title">Delete Semester</div>
					<div class="field-hint">This action cannot be undone.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="delete-semester-form">
				<input type="hidden" id="ds-id" name="id" />

				<div id="ds-error" class="alert alert-error" style="display:none;" role="alert"></div>

				<div class="modal-warning">
					<div id="ds-message" class="modal-warning-text">
						Are you sure you want to delete this semester?
					</div>
					<div id="ds-counts" class="field-hint" style="margin-top:.5rem;"></div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-danger" form="delete-semester-form">Delete</button>
			</footer>
		</div>
	</div>

	<!-- New Study Session Modal -->
	<div class="modal" id="new-study-session-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">New Study Session</div>
					<div class="field-hint">Create a recurring weekly study block for assignment work.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="new-study-session-form">

				<div id="nss-error" class="alert alert-error" style="display: none;" role="alert"></div>

				<div class="form-row">
					<label for="nss-day">Day</label>
					<select id="nss-day" name="dayOfWeek" required>
						<!-- populated by JS -->
					</select>
				</div>

				<div class="form-grid">
					<div class="form-row">
						<label for="nss-start">Start Time</label>
						<select id="nss-start" name="startTime" required>
							<!-- populated by JS -->
						</select>
						<div class="field-hint">15-minute increments.</div>
					</div>

					<div class="form-row">
						<label for="nss-duration">Duration</label>
						<select id="nss-duration" name="durationMinutes" required>
							<option value="15">15 mins</option>
							<option value="30">30 mins</option>
							<option value="45">45 mins</option>
							<option value="60">1 hour</option>
							<option value="75">1h 15m</option>
							<option value="90">1h 30m</option>
							<option value="120">2 hours</option>
							<option value="150">2h 30m</option>
							<option value="180">3 hours</option>
							<option value="240">4 hours</option>
						</select>
					</div>
				</div>

			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="new-study-session-form">Create</button>
			</footer>
		</div>
	</div>

	<!-- Edit Study Session Modal -->
	<div class="modal" id="edit-study-session-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">Edit Study Session</div>
					<div class="field-hint">Update a recurring weekly study block for assignment work.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="edit-study-session-form">
				<input type="hidden" id="ess-id" name="id" />

				<div id="ess-error" class="alert alert-error" style="display: none;" role="alert"></div>

				<div class="form-row">
					<label for="ess-day">Day</label>
					<select id="ess-day" name="dayOfWeek" required>
						<!-- populated by JS -->
					</select>
				</div>

				<div class="form-grid">
					<div class="form-row">
						<label for="ess-start">Start Time</label>
						<select id="ess-start" name="startTime" required>
							<!-- populated by JS -->
						</select>
						<div class="field-hint">15-minute increments.</div>
					</div>

					<div class="form-row">
						<label for="ess-duration">Duration</label>
						<select id="ess-duration" name="durationMinutes" required>
							<option value="15">15 mins</option>
							<option value="30">30 mins</option>
							<option value="45">45 mins</option>
							<option value="60">1 hour</option>
							<option value="75">1h 15m</option>
							<option value="90">1h 30m</option>
							<option value="120">2 hours</option>
							<option value="150">2h 30m</option>
							<option value="180">3 hours</option>
							<option value="240">4 hours</option>
						</select>
					</div>
				</div>

			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="edit-study-session-form">Save</button>
			</footer>
		</div>
	</div>

	<!-- Delete Study Session Modal -->
	<div class="modal" id="delete-study-session-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title" id="delete-study-session-title">Delete Study Session</div>
					<div class="field-hint">This action cannot be undone.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="delete-study-session-form">
				<input type="hidden" id="dss-id" name="id" />

				<div id="dss-error" class="alert alert-error" style="display:none;" role="alert"></div>

				<div class="modal-warning">
					<div id="dss-message" class="modal-warning-text">
						Are you sure you want to delete this study session?
					</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-danger" form="delete-study-session-form">Delete</button>
			</footer>
		</div>
	</div>

	<script src="/js/main.js"></script>
</body>
</html>
