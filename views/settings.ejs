<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="robots" content="noindex, nofollow">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="settings">
		<div class="container">

			<header class="ui-header">
				<div class="ui-title">
					<h1>Settings</h1>
					<div class="ui-subline">
						Manage your account and preferences.
					</div>
				</div>
			</header>

			<section class="ui-grid ui-grid--settings">
				<article class="ui-card">
					<h2 class="ui-card-title">Profile</h2>

					<form class="form" id="settings-profile-form">
						
						<div id="sp-error" class="alert alert-error" style="display:none;" role="alert"></div>

						<div class="form-row">
							<label for="sp-email">Email</label>
							<input 
								id="sp-email" 
								name="email" 
								type="email" 
								value="<%= user.email %>"
								disabled 
							/>
							<div class="field-hint">Your email cannot be changed.</div>
						</div>

						<div class="form-row">
							<label>Avatar</label>

							<div class="ui-user">
								<img 
									src="/api/settings/avatar" 
									class="ui-avatar"
									id="sp-avatar-preview"
								/>

								<input 
									type="file" 
									id="sp-avatar" 
									name="avatar" 
									accept="image/*"
								/>

								<button 
									type="button" 
									class="btn btn-small btn-danger" 
									id="sp-avatar-delete"
								>
									Remove
								</button>
							</div>
						</div>

						<div class="form-grid">
							<div class="form-row">
								<label for="sp-forename">Forename</label>
								<input id="sp-forename" name="forename" type="text" value="<%= user.forename %>" required />
							</div>

							<div class="form-row">
								<label for="sp-surname">Surname</label>
								<input id="sp-surname" name="surname" type="text" value="<%= user.surname %>" />
							</div>
						</div>

						<div class="ui-actions">
							<button type="button" class="btn btn-small" data-modal-open="change-password-modal">Change password</button>
							<button type="submit" class="btn btn-small btn-primary">Save</button>
						</div>
					</form>
				</article>

				<article class="ui-card">
					<h2 class="ui-card-title">Preferences</h2>

					<form class="form" id="settings-preferences-form">

						<div id="spf-error" class="alert alert-error" style="display:none;" role="alert"></div>

						<div class="form-row">
							<label for="spf-theme">Theme</label>

							<select id="spf-theme" name="theme">
								<option value="system" <%= settings.theme === "system" ? "selected" : "" %>>System</option>
								<option value="light"  <%= settings.theme === "light" ? "selected" : "" %>>Light</option>
								<option value="dark"   <%= settings.theme === "dark" ? "selected" : "" %>>Dark</option>
							</select>

							<div class="field-hint">
								System = follows your device settings.
							</div>
						</div>

						<div class="ui-actions">
							<button type="submit" class="btn btn-small btn-primary">Save</button>
						</div>

					</form>
				</article>

			</section>

		</div>
	</main>

	<%- include('partials/footer') %>

	<!-- Change Password Modal -->
	<div class="modal" id="change-password-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">Change Password</div>
					<div class="field-hint">Update your account password.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="change-password-form">
				<div id="cp-error" class="alert alert-error" style="display: none;"role="alert"></div>

				<div class="form-row">
					<label for="cp-current">Current Password</label>
					<input id="cp-current" name="currentPassword" type="password" required />
				</div>

				<div class="form-row">
					<label for="cp-new">New Password</label>
					<input id="cp-new" name="newPassword" type="password" required />
					<p class="field-hint">Use at least 8 characters.</p>
				</div>

				<div class="form-row">
					<label for="cp-confirm">Confirm New Password</label>
					<input id="cp-confirm" name="confirmPassword" type="password" required />
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="change-password-form">Change password</button>
			</footer>
		</div>
	</div>

	<script src="/js/main.js?v=<%= assetVersion %>"></script>
</body>
</html>
