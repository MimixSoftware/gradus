<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="robots" content="noindex, nofollow">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="stylesheet" href="/css/style.css">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="register">
		<section class="auth">
			<div class="auth-card">
				<img
					src="/images/logo.png"
					alt="Gradus logo"
					class="auth-logo"
				>

				<div id="register-start-view">
					<h1>Create account</h1>
					<p class="auth-subtitle">Start organising your work step by step.</p>

					<div
						id="auth-start-error"
						class="alert alert-error"
						style="display: none;"
						role="alert"
					></div>

					<form class="form" id="register-start-form">
						<div class="form-grid">
							<div class="form-row">
								<label for="forename">Forename <span class="required">*</span></label>
								<input
									id="forename"
									name="forename"
									type="text"
									autocomplete="given-name"
									required
								>
							</div>

							<div class="form-row">
								<label for="surname">Surname</label>
								<input
									id="surname"
									name="surname"
									type="text"
									autocomplete="family-name"
								>
							</div>
						</div>

						<div class="form-row">
							<label for="register-email">Email <span class="required">*</span></label>
							<input
								id="register-email"
								name="email"
								type="email"
								autocomplete="email"
								required
							>
						</div>

						<div class="form-row">
							<label for="password">Password <span class="required">*</span></label>
							<input
								id="password"
								name="password"
								type="password"
								autocomplete="new-password"
								required
							>
							<p class="field-hint">Use at least 8 characters.</p>
						</div>

						<div class="form-row">
							<label for="confirm-password">Confirm password <span class="required">*</span></label>
							<input
								id="confirm-password"
								name="confirmPassword"
								type="password"
								autocomplete="new-password"
								required
							>
						</div>

						<button class="btn btn-primary btn-large form-submit" type="submit">
							Next
						</button>

						<p class="auth-alt">
							Already have an account?
							<a href="/login">Login</a>
						</p>
					</form>
				</div>

				<div id="register-verify-view" style="display: none;">
					<h1>Verify your email</h1>
					<p class="auth-subtitle">
						We sent a 6-digit verification code to
						<strong id="register-verify-email-text"></strong>.
					</p>

					<div
						id="auth-verify-error"
						class="alert alert-error"
						style="display: none;"
						role="alert"
					></div>

					<form class="form" id="register-verify-form">
						<input
							id="register-verify-email"
							name="email"
							type="hidden"
						>

						<div class="form-row">
							<label for="verification-code">Verification code <span class="required">*</span></label>
							<input
								id="verification-code"
								name="code"
								type="text"
								inputmode="numeric"
								autocomplete="one-time-code"
								maxlength="6"
								placeholder="Enter 6-digit code"
								required
							>
							<p class="field-hint">
								The code expires in <span id="register-expiry-minutes"></span> minutes.
								<a href="#" id="register-resend-link" class="ui-link">Resend</a>
							</p>
						</div>

						<button class="btn btn-primary btn-large form-submit" type="submit">
							Verify and create account
						</button>

						<p class="auth-alt">
							Already have an account?
							<a href="/login">Login</a>
						</p>
					</form>
				</div>
			</div>
		</section>
	</main>

	<%- include('partials/footer') %>

	<script src="/js/main.js"></script>
</body>
</html>
