<!DOCTYPE html>
<%- include('partials/htmlStart') %>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="description" content="Gradus is a student planner that helps you capture, plan, and schedule academic work step by step.">
	<meta name="robots" content="index, follow">

	<meta property="og:title" content="Gradus - Student Planner">
	<meta property="og:description" content="Capture, plan, and schedule your academic work with ease.">
	<meta property="og:type" content="website">
	<meta property="og:url" content="https://gradus.tools">
	<meta property="og:image" content="https://gradus.tools/images/logo.png">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
	<link rel="stylesheet" href="/css/style.css?v=<%= assetVersion %>">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="index">
		<section class="hero">
			<div class="hero-slideshow">
				<div class="hero-slides">
					<div class="hero-slide active">
						<img src="/images/screenshot1.png" alt="Dashboard showing modules, assignments, and upcoming tasks in Gradus">
						<div class="hero-caption">A clear overview of your modules, assignments, and upcoming work.</div>
					</div>

					<div class="hero-slide">
						<img src="/images/screenshot2.png" alt="Task list view of an assignment in Gradus">
						<div class="hero-caption">Break assignments into manageable tasks and track progress.</div>
					</div>

					<div class="hero-slide">
						<img src="/images/screenshot3.png" alt="AI-powered task time estimates in Gradus">
						<div class="hero-caption">Get intelligent time estimates for tasks using built-in AI assistance.</div>
					</div>

					<div class="hero-slide">
						<img src="/images/screenshot4.png" alt="Calendar view automatically scheduling study sessions in Gradus">
						<div class="hero-caption">Automatically schedule your work into available study sessions in seconds.</div>
					</div>
				</div>

				<div class="hero-dots" role="tablist">
					<button class="hero-dot active" type="button"></button>
					<button class="hero-dot" type="button"></button>
					<button class="hero-dot" type="button"></button>
					<button class="hero-dot" type="button"></button>
				</div>
			</div>

			<h1>Welcome to Gradus</h1>

			<p>Gradus is a student planner that helps you capture, plan, and schedule academic work step by step.</p>

			<div class="hero-buttons">
				<a href="/register" class="btn btn-primary btn-large">
					Register now
				</a>
				<a href="/login" class="btn btn-large btn-secondary">
					Have an account? Login
				</a>
			</div>
		</section>
	</main>

	<%- include('partials/footer') %>

	<script src="/js/main.js?v=<%= assetVersion %>"></script>
</body>
</html>
