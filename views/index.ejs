<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<title><%= title %> - Gradus</title>

	<meta name="description" content="Gradus is a student-focused task and time-management system that helps plan, prioritise, and schedule academic work step by step.">
	<meta name="robots" content="index, follow">

	<meta property="og:title" content="Gradus - Student Planning System">
	<meta property="og:description" content="Plan, prioritise, and schedule your academic work with ease.">
	<meta property="og:type" content="website">
	<meta property="og:url" content="https://gradus.tools">
	<meta property="og:image" content="https://gradus.tools/images/logo.png">

	<link rel="icon" href="/images/favicon.ico">
	<link rel="stylesheet" href="/css/style.css">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="index">
		<section class="hero">
			<img
				src="/images/logo.png"
				alt="Gradus logo"
				class="hero-logo"
			>

			<h1>Welcome to Gradus</h1>

			<p>
				Gradus is a student-focused task and time-management system that helps
				plan, prioritise, and schedule academic work step by step.
			</p>

			<a href="/register" class="btn btn-primary btn-large">
				Register now
			</a>
		</section>
	</main>

	<%- include('partials/footer') %>

	<script src="/js/main.js"></script>
</body>
</html>
