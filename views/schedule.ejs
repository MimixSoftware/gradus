<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title><%= title %> - Gradus</title>
	<link rel="icon" href="/images/favicon.ico">
	<link rel="stylesheet" href="/css/style.css">
</head>
<body>

	<%- include('partials/header') %>

	<main class="page" data-page="schedule">
		<div class="container">

			<header class="ui-header">
				<div class="ui-title">
					<h1>My Schedule</h1>
					<div class="ui-subline">
						<a class="ui-link" href="#" id="prev-week-btn">← Prev</a>
						<span id="selected-week-name"></span>
						<a class="ui-link" href="#" id="next-week-btn">Next →</a>
					</div>
				</div>
			</header>

			<section class="ui-grid ui-grid--double">
				<article class="ui-card">
					<h2 class="ui-card-title">Schedule</h2>

					<div class="ui-list scroll-container" data-list="schedule"></div>

					<div class="ui-actions">
						<button type="button" class="btn btn-small" data-link="/study-sessions">Manage Study Sessions</button>
					</div>
				</article>

				<article class="ui-card">
					<h2 class="ui-card-title">Unscheduled Tasks</h2>

					<div class="ui-list ui-list--editable" data-list="unscheduledTasks"></div>

					<div class="ui-actions">
						<button type="button" class="btn btn-small" data-modal-open="new-study-session-modal">Auto-schedule</button>
					</div>
				</article>
			</section>
		</div>
	</main>

	<%- include('partials/footer') %>

	<!-- Schedule Task Modal -->
	<div class="modal" id="schedule-task-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">Schedule Task</div>
					<div class="field-hint">Assign this task to a study session.</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="schedule-task-form">

				<div id="st-error" class="alert alert-error" style="display:none;" role="alert"></div>

				<div class="form-row">
					<label for="st-task-name">Task</label>
					<input id="st-task-name" type="text" readonly />
				</div>

				<div class="form-row">
					<label for="st-date">Date</label>
					<input id="st-date" name="date" type="date" required />
					<div class="field-hint">Select the day you want to study this task.</div>
				</div>

				<div class="form-row">
					<label for="st-session">Study Session</label>
					<select id="st-session" name="studySessionId" required>
						<option value="" disabled selected>Select a study session…</option>
						<!-- populated by JS -->
					</select>

					<div class="field-hint">Available study sessions for the selected day.</div>
				</div>

				<div class="form-row">
					<label for="st-duration">Duration (minutes)</label>

					<input
						id="st-duration"
						name="durationMinutes"
						type="number"
						min="15"
						max="480"
						step="15"
						required
					/>

					<div class="field-hint">How much time from this session should be used for the task.</div>
				</div>

				<div class="form-row">
					<div class="field-hint" id="st-remaining-info">Remaining task time: —</div>
				</div>

			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="schedule-task-form">Schedule</button>
			</footer>
		</div>
	</div>

	<!-- Schedule Duration Modal -->
	<div class="modal" id="schedule-duration-modal">
		<div class="modal-overlay" data-modal-close></div>

		<div class="modal-dialog" role="dialog">
			<header class="modal-header">
				<div>
					<div class="modal-title">Schedule Task</div>
					<div class="field-hint">How much of the task to schedule for this study session?</div>
				</div>

				<button type="button" class="modal-close" data-modal-close>✕</button>
			</header>

			<form class="modal-body form" id="schedule-duration-form">
				<input type="hidden" id="sd-id" name="id" />

				<div class="form-row">
					<label for="sd-duration">Duration (minutes)</label>

					<input
						id="sd-duration"
						name="durationMinutes"
						type="number"
						min="15"
						max="480"
						step="15"
						required
					/>

					<div class="field-hint">How much time from this session should be used for the task.</div>
				</div>

				<div class="form-row">
					<div class="field-hint" id="sd-remaining-info">Remaining task time: —</div>
				</div>
			</form>

			<footer class="modal-footer">
				<button type="button" class="btn btn-small" data-modal-close>Cancel</button>
				<button type="submit" class="btn btn-small btn-primary" form="schedule-duration-form">Schedule</button>
			</footer>
		</div>
	</div>

	<script src="/js/main.js"></script>
</body>
</html>
